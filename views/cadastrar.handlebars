<div style="font-family: Arial, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; border: 1px solid #ddd; border-radius: 8px; background-color: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
    
    <h2 style="color: #2E7D32; margin-top: 0; border-bottom: 2px solid #4CAF50; padding-bottom: 10px;">📝 Adicionar ao Almanaque</h2>

    <form action="/salvar" method="POST" style="display: flex; flex-direction: column; gap: 15px; margin-top: 20px;">
        
        <div>
            <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #444;">Nome da Planta / Zumbi:</label>
            <input type="text" name="nome" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
        </div>

        <div style="display: flex; gap: 10px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #444;">Tipo:</label>
                <input type="text" name="tipo" placeholder="Ex: Defesa, Ataque" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #444;">Custo de Sol:</label>
                <input type="number" name="custoemsol" placeholder="Ex: 125" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
        </div>

        <div style="display: flex; gap: 10px;">
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #444;">Recarregamento:</label>
                <input type="text" name="recarregamento" placeholder="Ex: Lento, Rápido" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #444;">Dano:</label>
                <input type="text" name="dano" placeholder="Ex: Massivo, Nenhum" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
        </div>

        <div>
            <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #444;">Descrição do Almanaque:</label>
            <textarea name="descricao" rows="3" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; resize: none;"></textarea>
        </div>

        <div style="margin-top: 10px; display: flex; align-items: center; gap: 15px;">
            <button type="submit" style="background-color: #4CAF50; color: white; border: none; padding: 10px 20px; border-radius: 5px; font-weight: bold; cursor: pointer;">Salvar no Almanaque</button>
            <a href="/" style="color: #666; text-decoration: none; align-self: center;">Voltar</a>
        </div>
    </form>
</div>
